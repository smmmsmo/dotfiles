# -----------------------------------------------------------------------------
# tmux.conf
# -----------------------------------------------------------------------------
# Clean tmux config written from scratch.
# Main config path: ~/.config/tmux/tmux.conf
# Reload inside tmux with: prefix + r
#
# Design goals:
# - obvious prefix indicator
# - small number of bindings
# - good defaults for shell + Vim/Neovim
# - no plugin dependency


# -----------------------------------------------------------------------------
# Prefix key
# -----------------------------------------------------------------------------
# Use Ctrl-a as primary prefix and keep Ctrl-Space as secondary prefix.
# This lets you use either habit while we troubleshoot key behavior.
unbind C-b
set -g prefix C-a
set -g prefix2 C-Space
bind C-a send-prefix


# -----------------------------------------------------------------------------
# Terminal and responsiveness
# -----------------------------------------------------------------------------
# Tell programs inside tmux to use the tmux terminal entry.
set -g default-terminal "tmux-256color"

# Advertise RGB support to apps like Neovim.
set -ag terminal-overrides ",*:RGB"

# Pass through undercurl / colored underline support when available.
set -as terminal-overrides ',*:Smulx=\E[4::%p1%dm'
set -as terminal-overrides ',*:Setulc=\E[58::2::%p1%{65536}%/%d::%p1%{256}%/%{255}%&%d::%p1%{255}%&%d%;m'

# Make Escape feel fast in Vim/Neovim.
set -sg escape-time 10

# Allow repeatable resize bindings for a short period after prefix.
set -g repeat-time 600

# Keep enough scrollback for logs and long command output.
set -g history-limit 100000


# -----------------------------------------------------------------------------
# Window and pane behavior
# -----------------------------------------------------------------------------
# Start counting from 1 so prefix+1 selects window 1.
set -g base-index 1
set -g pane-base-index 1
set -g renumber-windows on

# Mouse is convenient for scrolling, selecting panes, and resizing.
set -g mouse on

# Send focus events to applications that understand them.
set -g focus-events on

# Let the current client size drive window size more aggressively.
set -g aggressive-resize on


# -----------------------------------------------------------------------------
# Quality-of-life bindings
# -----------------------------------------------------------------------------
# Reload this file quickly while iterating on the config.
bind r source-file ~/.config/tmux/tmux.conf \; display-message "tmux config reloaded"

# Open new windows and splits in the current pane's directory.
bind c new-window -c "#{pane_current_path}"
unbind '"'
unbind %
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind \\ split-window -h -c "#{pane_current_path}"

# Vim-style pane movement.
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# Repeatable pane resizing.
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# Fast window cycling without prefix.
bind -n M-[ previous-window
bind -n M-] next-window

# Kill pane without the confirmation prompt.
bind x kill-pane

# Keep tmux default paste behavior on prefix + p.
bind p paste-buffer

# Session tree is a handy built-in picker.
bind s choose-tree -Zs


# -----------------------------------------------------------------------------
# Copy mode
# -----------------------------------------------------------------------------
# Use vi keys in copy mode.
set -g mode-keys vi

# A more memorable entry point than prefix + [.
bind v copy-mode

# Copy-mode bindings that feel like Vim visual mode.
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi C-v send-keys -X rectangle-toggle
bind -T copy-mode-vi y send-keys -X copy-selection-and-cancel


# -----------------------------------------------------------------------------
# Status bar
# -----------------------------------------------------------------------------
# Refresh every second so the prefix indicator updates immediately.
set -g status-interval 1
set -g status-position top
set -g status-justify left
set -g status-left-length 60
set -g status-right-length 60

# Neutral dark theme with one strong accent color.
set -g status-style "bg=colour234,fg=colour252"

# This is the main prefix indicator.
# We key off client_key_table instead of client_prefix because client_prefix can
# be too short to notice on some terminals.
#
# If key table is "prefix", show blue PREFIX text.
# Otherwise show a dim PREFIX label so the location is always obvious.
set -g status-left '#{?#{==:#{client_key_table},prefix},#[fg=colour231,bg=colour33,bold] PREFIX #[default],#[fg=colour250,bg=colour240] PREFIX #[default]}#[fg=colour81,bg=colour234,bold] #S '

# Keep the right side simple and readable.
set -g status-right '#[fg=colour245]%Y-%m-%d #[fg=colour39,bold]%H:%M '

# Window tabs: calm when inactive, bright when active.
set -g window-status-separator ''
set -g window-status-format ' #[fg=colour245]#I:#W '
set -g window-status-current-format '#[fg=colour232,bg=colour81,bold] #I:#W #[default]'
setw -g window-status-activity-style 'fg=colour220,bold'
setw -g window-status-bell-style 'fg=colour196,bold'


# -----------------------------------------------------------------------------
# Pane and message styling
# -----------------------------------------------------------------------------
set -g pane-border-style 'fg=colour238'
set -g pane-active-border-style 'fg=colour81'
set -g message-style 'fg=colour232,bg=colour81,bold'
set -g message-command-style 'fg=colour231,bg=colour39,bold'
set -g mode-style 'fg=colour231,bg=colour24,bold'
set -g display-time 2000
set -g display-panes-time 2000


# -----------------------------------------------------------------------------
# Useful defaults worth remembering
# -----------------------------------------------------------------------------
# prefix + c   -> new window in current directory
# prefix + |   -> vertical split in current directory
# prefix + -   -> horizontal split in current directory
# prefix + h/j/k/l -> move between panes
# prefix + H/J/K/L -> resize panes
# prefix + v   -> enter copy mode
# prefix + r   -> reload this config
