[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[user]
	name = S.M. Mostofa Morshed Sayeem
	email = 198875870+smmmsmo@users.noreply.github.com

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	syntax-theme = tokyonight
	line-numbers = true
	side-by-side = false

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[color]
	ui = true
